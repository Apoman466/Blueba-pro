<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:padding="16dp">

    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <Button android:id="@+id/btnConnect" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="BAĞLAN" android:background="#333333" android:textColor="#FFFFFF"/>
        <Button android:id="@+id/btnSettings" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="AYARLAR" android:layout_marginLeft="10dp" android:background="#333333" android:textColor="#FFFFFF"/>
    </LinearLayout>

    <RelativeLayout
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:layout_alignParentLeft="true"
        android:layout_centerVertical="true">
        <Button android:id="@+id/btnF" android:layout_width="60dp" android:layout_height="60dp" android:text="↑" android:layout_centerHorizontal="true" android:layout_alignParentTop="true"/>
        <Button android:id="@+id/btnL" android:layout_width="60dp" android:layout_height="60dp" android:text="←" android:layout_centerVertical="true" android:layout_alignParentLeft="true"/>
        <Button android:id="@+id/btnR" android:layout_width="60dp" android:layout_height="60dp" android:text="→" android:layout_centerVertical="true" android:layout_alignParentRight="true"/>
        <Button android:id="@+id/btnB" android:layout_width="60dp" android:layout_height="60dp" android:text="↓" android:layout_centerHorizontal="true" android:layout_alignParentBottom="true"/>
    </RelativeLayout>

    <RelativeLayout
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:layout_alignParentRight="true"
        android:layout_centerVertical="true">
        <Button android:id="@+id/btnTriangle" android:layout_width="60dp" android:layout_height="60dp" android:text="Δ" android:layout_centerHorizontal="true" android:layout_alignParentTop="true" android:background="#2E7D32"/>
        <Button android:id="@+id/btnSquare" android:layout_width="60dp" android:layout_height="60dp" android:text="□" android:layout_centerVertical="true" android:layout_alignParentLeft="true" android:background="#D84315"/>
        <Button android:id="@+id/btnCircle" android:layout_width="60dp" android:layout_height="60dp" android:text="O" android:layout_centerVertical="true" android:layout_alignParentRight="true" android:background="#1565C0"/>
        <Button android:id="@+id/btnX" android:layout_width="60dp" android:layout_height="60dp" android:text="X" android:layout_centerHorizontal="true" android:layout_alignParentBottom="true" android:background="#C62828"/>
    </RelativeLayout>

</RelativeLayout>

